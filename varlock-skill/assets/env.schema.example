# Varlock Example Schema
# This file defines the structure, constraints, and documentation for your environment variables.

@type=enum(development, preview, production, test)
@required
__VARLOCK_ENV=development

---

@type=string
@required
@example="my-awesome-app"
APP_NAME=

@type=url(prependHttps=true)
@required
APP_URL=

@type=port(min=1024, max=65535)
@example=3000
PORT=

---
# Database Configuration

@type=string
@description="The main database host"
DB_HOST=

@type=string
@required
@sensitive
@description="Database password"
DB_PASS=

---
# Third Party Services

@type=string(startsWith="sk_")
@sensitive
@required=forEnv(production)
STRIPE_SECRET_KEY=

@type=opServiceAccountToken
@sensitive
OP_SERVICE_ACCOUNT_TOKEN=
